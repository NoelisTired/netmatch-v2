@model Presentation.Models.DayViewModel
@{
    ViewData["Title"] = "Dag toevoegen";
}

<div class="nm-page-head">
    <h1>Dag toevoegen</h1>
</div>

<div class="nm-surface p-4 col-lg-6">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <form asp-action="Create" method="post">
        <input type="hidden" asp-for="QuoteId" />

    <div class="mb-3">
        <label asp-for="DayNumber" class="form-label">Dagnummer</label>
        <input asp-for="DayNumber" type="number" min="1" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Date" class="form-label">Datum</label>
        <input asp-for="Date" type="date" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Title" class="form-label">Titel <span class="text-muted">(optioneel)</span></label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label">Omschrijving <span class="text-muted">(optioneel)</span></label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
    </div>

        <button type="submit" class="btn btn-primary">Opslaan</button>
        <a asp-action="Index" asp-route-quoteId="@Model.QuoteId" class="btn btn-link">Annuleren</a>
    </form>
</div>

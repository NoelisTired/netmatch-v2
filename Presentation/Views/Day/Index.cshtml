@using Logic.Models
@model IEnumerable<Day>
@{
    var quoteId = (int)ViewBag.QuoteId;
    ViewData["Title"] = "Dag-tot-dag";
}

<div class="mb-8 flex flex-wrap items-end justify-between gap-4 reveal">
    <div>
        <p class="eyebrow mb-2">@ViewBag.QuoteTitle</p>
        <h1 class="font-display text-3xl font-bold sm:text-4xl">Dag-tot-dag</h1>
    </div>
    <a asp-action="Create" asp-route-quoteId="@quoteId" class="btn btn-accent">Dag toevoegen</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info reveal">Deze offerte heeft nog geen dagen.</div>
}
else
{
    <div class="card-glass reveal overflow-hidden">
        <table class="table-glass">
            <thead>
                <tr>
                    <th>Dag</th>
                    <th>Datum</th>
                    <th>Titel</th>
                    <th class="text-right">Acties</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var day in Model)
                {
                    <tr>
                        <td>@day.DayNumber</td>
                        <td>@day.Date.ToString("dd-MM-yyyy")</td>
                        <td>@day.Title</td>
                        <td>
                            <div class="flex flex-wrap justify-end gap-2">
                                <a asp-controller="Transport" asp-action="Index" asp-route-dayId="@day.Id" class="btn btn-ghost btn-sm">Transport</a>
                                <a asp-controller="Accommodation" asp-action="Index" asp-route-dayId="@day.Id" class="btn btn-ghost btn-sm">Accommodatie</a>
                                <a asp-action="Edit" asp-route-id="@day.Id" class="btn btn-primary btn-sm">Bewerken</a>
                                <form asp-action="Delete" asp-route-id="@day.Id" asp-route-quoteId="@quoteId"
                                      method="post" class="inline"
                                      onsubmit="return confirm('Deze dag verwijderen?');">
                                    <button type="submit" class="btn btn-danger btn-sm">Verwijderen</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<a asp-controller="Quote" asp-action="Details" asp-route-id="@quoteId" class="btn-link mt-6 inline-block text-sm font-semibold">Terug naar offerte</a>

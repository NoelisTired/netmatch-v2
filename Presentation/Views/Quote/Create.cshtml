@model Presentation.Models.QuoteViewModel
@{
    ViewData["Title"] = "Nieuwe offerte";
}

<div class="nm-page-head">
    <h1>Nieuwe offerte</h1>
</div>

<div class="nm-surface p-4 col-lg-6">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label asp-for="Title" class="form-label">Titel</label>
            <input asp-for="Title" class="form-control" autofocus />
        </div>

        <div class="mb-3">
            <label asp-for="Language" class="form-label">Taal</label>
            <select asp-for="Language" class="form-select">
                <option value="">-- Kies een taal --</option>
                <option value="NL">Nederlands</option>
                <option value="EN">Engels</option>
                <option value="DE">Duits</option>
                <option value="FR">Frans</option>
            </select>
        </div>

        <div class="d-flex gap-2 mt-2">
            <button type="submit" class="btn btn-primary">Opslaan</button>
            <a asp-action="Index" class="btn btn-link">Annuleren</a>
        </div>
    </form>
</div>

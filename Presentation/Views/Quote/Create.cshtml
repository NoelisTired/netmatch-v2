@model Presentation.Models.QuoteViewModel
@{
    ViewData["Title"] = L["Nieuwe offerte"];
    ViewData["Crumbs"] = new (string, string?)[]
    {
        (L["Offertes"].Value, Url.Action("Index")),
        (L["Nieuwe offerte"].Value, null)
    };
}

<div class="mb-6">
    <h1 class="text-xl font-semibold" style="color:var(--text-primary);">@L["Nieuwe offerte"]</h1>
    <p class="mt-0.5 text-sm" style="color:var(--text-secondary);">@L["Start met een titel en taal; dagen en prijzen voeg je daarna toe."]</p>
</div>

<div class="card max-w-2xl">
    <div class="card-header">
        <span class="card-title">@L["Offertegegevens"]</span>
    </div>
    <form asp-action="Create" method="post" class="p-5 sm:p-6">
        <div asp-validation-summary="All" class="validation-errors mb-5"></div>

        <div class="space-y-5">
            <div>
                <label asp-for="Title" class="field-label">@L["Titel"] <span class="req">*</span></label>
                <input asp-for="Title" class="field" autofocus placeholder="@L["Bijv. Rondreis Japan, 14 dagen"]"/>
            </div>

            <div>
                <label asp-for="Language" class="field-label">@L["Taal"] <span class="req">*</span></label>
                <select asp-for="Language" class="field" data-ts>
                    <option value="">@L["Kies een taal"]</option>
                    <option value="NL">Nederlands</option>
                    <option value="EN">Engels</option>
                    <option value="DE">Duits</option>
                    <option value="FR">Frans</option>
                </select>
                <p class="field-hint">@L["De taal waarin de offerte voor de klant wordt opgesteld."]</p>
            </div>
        </div>

        <div class="mt-6 flex items-center justify-end gap-2.5 border-t pt-5" style="border-color:var(--border);">
            <a asp-action="Index" class="btn btn-ghost">@L["Annuleren"]</a>
            <button type="submit" class="btn btn-primary">
                <i data-lucide="check" class="h-4 w-4"></i>
                @L["Offerte aanmaken"]
            </button>
        </div>
    </form>
</div>

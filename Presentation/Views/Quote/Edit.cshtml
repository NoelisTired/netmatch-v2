@model Presentation.Models.QuoteViewModel
@{
    ViewData["Title"] = "Offerte bewerken";
}

<div class="mb-8 reveal">
    <p class="eyebrow mb-2">TourWeb Portal</p>
    <h1 class="font-display text-3xl font-bold sm:text-4xl">Offerte bewerken</h1>
</div>

<div class="card-glass reveal max-w-xl p-6 sm:p-7">
    <div asp-validation-summary="All" class="mb-4 text-sm" style="color:#f87171;"></div>

    <form asp-action="Edit" method="post" class="space-y-5">
        <input type="hidden" asp-for="Id" />

        <div>
            <label asp-for="Title" class="field-label">Titel</label>
            <input asp-for="Title" class="field" />
        </div>

        <div>
            <label asp-for="Language" class="field-label">Taal</label>
            <select asp-for="Language" class="field">
                <option value="NL">Nederlands</option>
                <option value="EN">Engels</option>
                <option value="DE">Duits</option>
                <option value="FR">Frans</option>
            </select>
        </div>

        <div>
            <label asp-for="Status" class="field-label">Status</label>
            <select asp-for="Status" class="field">
                <option value="concept">Concept</option>
                <option value="definitief">Definitief</option>
            </select>
        </div>

        <div class="flex items-center gap-3 pt-1">
            <button type="submit" class="btn btn-primary">Opslaan</button>
            <a asp-action="Index" class="btn-link text-sm font-semibold">Annuleren</a>
        </div>
    </form>
</div>

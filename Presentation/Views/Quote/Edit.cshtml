@model Presentation.Models.QuoteViewModel
@{
    ViewData["Title"] = L["Offerte bewerken"];
    ViewData["Crumbs"] = new (string, string?)[]
    {
        (L["Offertes"].Value, Url.Action("Index")),
        (Model.Title ?? L["Offerte bewerken"].Value, Url.Action("Details", new { id = Model.Id })),
        (L["Bewerken"].Value, null)
    };
    var isFinal = string.Equals(Model.Status, "definitief", StringComparison.OrdinalIgnoreCase);
}

<div class="mb-6">
    <h1 class="text-xl font-semibold" style="color:var(--text-primary);">@L["Offerte bewerken"]</h1>
    <p class="mt-0.5 text-sm" style="color:var(--text-secondary);">@L["Pas de titel, taal of status van deze offerte aan."]</p>
</div>

<div class="card max-w-2xl">
    <div class="card-header">
        <span class="card-title">@L["Offertegegevens"]</span>
    </div>
    <form asp-action="Edit" method="post" class="p-5 sm:p-6">
        <div asp-validation-summary="All" class="validation-errors mb-5"></div>
        <input type="hidden" asp-for="Id"/>

        <div class="space-y-5">
            <div>
                <label asp-for="Title" class="field-label">@L["Titel"] <span class="req">*</span></label>
                <input asp-for="Title" class="field"/>
            </div>

            <div>
                <label asp-for="Language" class="field-label">@L["Taal"] <span class="req">*</span></label>
                <select asp-for="Language" class="field" data-ts>
                    <option value="NL">Nederlands</option>
                    <option value="EN">Engels</option>
                    <option value="DE">Duits</option>
                    <option value="FR">Frans</option>
                </select>
            </div>

            <div>
                <span class="field-label">@L["Status"]</span>
                <div class="seg">
                    <label>
                        <input type="radio" name="Status" value="concept" checked="@(!isFinal)"/>
                        <i data-lucide="pencil-line" class="h-3.5 w-3.5"></i>
                        @L["Concept"]
                    </label>
                    <label>
                        <input type="radio" name="Status" value="definitief" checked="@isFinal"/>
                        <i data-lucide="circle-check-big" class="h-3.5 w-3.5"></i>
                        @L["Definitief"]
                    </label>
                </div>
                <p class="field-hint">@L["Definitieve offertes zijn klaar om met de klant te delen."]</p>
            </div>
        </div>

        <div class="mt-6 flex items-center justify-end gap-2.5 border-t pt-5" style="border-color:var(--border);">
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-ghost">@L["Annuleren"]</a>
            <button type="submit" class="btn btn-primary">
                <i data-lucide="check" class="h-4 w-4"></i>
                @L["Wijzigingen opslaan"]
            </button>
        </div>
    </form>
</div>

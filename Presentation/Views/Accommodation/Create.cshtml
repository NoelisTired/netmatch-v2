@model Presentation.Models.AccommodationViewModel
@{
    ViewData["Title"] = "Accommodatie toevoegen";
}

<div class="mb-8 flex flex-wrap items-end justify-between gap-4 reveal">
    <div>
        <p class="eyebrow mb-2">TourWeb Portal</p>
        <h1 class="font-display text-3xl font-bold sm:text-4xl">Accommodatie toevoegen</h1>
    </div>
</div>

<div class="card-glass reveal max-w-xl p-6 sm:p-7">
    <div asp-validation-summary="All" class="mb-4 text-sm" style="color:#f87171;"></div>

    <form asp-action="Create" method="post" enctype="multipart/form-data" class="space-y-5">
        <input type="hidden" asp-for="DayId" />

        <div>
            <label asp-for="Name" class="field-label">Naam</label>
            <input asp-for="Name" class="field" autofocus />
        </div>

        <div>
            <label asp-for="Address" class="field-label">Adres <span style="color:var(--text-secondary);">(optioneel)</span></label>
            <input asp-for="Address" class="field" />
        </div>

        <div>
            <label asp-for="Description" class="field-label">Omschrijving <span style="color:var(--text-secondary);">(optioneel)</span></label>
            <textarea asp-for="Description" class="field" rows="3"></textarea>
        </div>

        <div>
            <label asp-for="Image" class="field-label">Afbeelding <span style="color:var(--text-secondary);">(optioneel, max 5 MB)</span></label>
            <input asp-for="Image" type="file" class="field" accept="image/png,image/jpeg,image/webp" />
        </div>

        <div class="flex items-center gap-3 pt-1">
            <button type="submit" class="btn btn-primary">Opslaan</button>
            <a asp-action="Index" asp-route-dayId="@Model.DayId" class="btn-link text-sm font-semibold">Annuleren</a>
        </div>
    </form>
</div>

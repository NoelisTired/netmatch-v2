@using Logic.Models
@model IEnumerable<Accommodation>
@{
    var dayId = (int)ViewBag.DayId;
    var quoteId = (int)ViewBag.QuoteId;
    ViewData["Title"] = L["Accommodatie"];
    ViewData["Crumbs"] = new (string, string?)[]
    {
        (L["Offertes"].Value, Url.Action("Index", "Quote")),
        (L["Offerte"].Value, Url.Action("Details", "Quote", new { id = quoteId })),
        ($"{L["Accommodatie"].Value} ({L["Dag"].Value} {ViewBag.DayNumber})", null)
    };
    var accommodations = Model.ToList();
}

<div class="mb-6 flex flex-wrap items-center justify-between gap-3">
    <div>
        <h1 class="text-xl font-semibold" style="color:var(--text-primary);">@L["Accommodatie"]</h1>
        <p class="mt-0.5 text-sm" style="color:var(--text-secondary);">@L["Dag"] @ViewBag.DayNumber</p>
    </div>
    <a asp-action="Create" asp-route-dayId="@dayId" class="btn btn-primary">
        <i data-lucide="plus" class="h-4 w-4"></i>
        @L["Accommodatie toevoegen"]
    </a>
</div>

@if (accommodations.Count == 0)
{
    <div class="empty-state">
        <span class="empty-icon"><i data-lucide="bed-double" class="h-5 w-5"></i></span>
        <p class="text-sm font-medium" style="color:var(--text-primary);">@L["Nog geen accommodatie"]</p>
        <p class="max-w-sm text-sm" style="color:var(--text-secondary);">@L["Deze dag heeft nog geen accommodatie."]</p>
        <a asp-action="Create" asp-route-dayId="@dayId" class="btn btn-primary btn-sm mt-3">@L["Accommodatie toevoegen"]</a>
    </div>
}
else
{
    <div class="card overflow-x-auto">
        <table class="table-data">
            <thead>
            <tr>
                <th class="w-20">@L["Foto"]</th>
                <th>@L["Naam"]</th>
                <th>@L["Adres"]</th>
                <th class="text-right">@L["Acties"]</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var accommodation in accommodations)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(accommodation.ImagePath))
                        {
                            <a href="@accommodation.ImagePath" class="glightbox thumb h-11 w-16"
                               data-gallery="accommodations" data-glightbox="title: @accommodation.Name">
                                <img src="@accommodation.ImagePath" alt="@accommodation.Name" loading="lazy"/>
                            </a>
                        }
                        else
                        {
                            <span class="thumb-placeholder h-11 w-16">
                                <i data-lucide="image" class="h-4 w-4"></i>
                            </span>
                        }
                    </td>
                    <td class="font-medium" style="color:var(--text-primary);">@accommodation.Name</td>
                    <td>@(accommodation.Address ?? "-")</td>
                    <td>
                        <div class="flex flex-wrap items-center justify-end gap-1">
                            <a asp-controller="RoomType" asp-action="Index" asp-route-accommodationId="@accommodation.Id" class="btn btn-ghost btn-sm">
                                <i data-lucide="bed-single" class="h-3.5 w-3.5"></i>
                                @L["Kamertypes"]
                            </a>
                            <a asp-action="Edit" asp-route-id="@accommodation.Id" class="btn-icon" title="@L["Bewerken"]" aria-label="@L["Bewerken"]">
                                <i data-lucide="pencil" class="h-4 w-4"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@accommodation.Id" asp-route-dayId="@dayId"
                                  method="post" class="inline" data-confirm="@L["Deze accommodatie verwijderen?"]">
                                <button type="submit" class="btn-icon btn-icon-danger" title="@L["Verwijderen"]" aria-label="@L["Verwijderen"]">
                                    <i data-lucide="trash-2" class="h-4 w-4"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

<a asp-controller="Day" asp-action="Index" asp-route-quoteId="@quoteId" class="btn-link mt-5 text-sm">
    <i data-lucide="arrow-left" class="h-3.5 w-3.5"></i>
    @L["Terug naar dag-tot-dag"]
</a>

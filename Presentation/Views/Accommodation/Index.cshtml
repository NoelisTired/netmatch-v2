@using Logic.Models
@model IEnumerable<Accommodation>
@{
    var dayId = (int)ViewBag.DayId;
    var quoteId = (int)ViewBag.QuoteId;
    ViewData["Title"] = "Accommodatie";
}

<div class="mb-8 flex flex-wrap items-end justify-between gap-4 reveal">
    <div>
        <p class="eyebrow mb-2">Dag @ViewBag.DayNumber</p>
        <h1 class="font-display text-3xl font-bold sm:text-4xl">Accommodatie</h1>
    </div>
    <a asp-action="Create" asp-route-dayId="@dayId" class="btn btn-accent">Accommodatie toevoegen</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info reveal">Deze dag heeft nog geen accommodatie.</div>
}
else
{
    <div class="card-glass reveal overflow-hidden">
        <table class="table-glass">
            <thead>
                <tr>
                    <th>Naam</th>
                    <th>Adres</th>
                    <th class="text-right">Acties</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var accommodation in Model)
                {
                    <tr>
                        <td>@accommodation.Name</td>
                        <td>@(accommodation.Address ?? "-")</td>
                        <td>
                            <div class="flex flex-wrap justify-end gap-2">
                                <a asp-controller="RoomType" asp-action="Index" asp-route-accommodationId="@accommodation.Id" class="btn btn-ghost btn-sm">Kamertypes</a>
                                <a asp-action="Edit" asp-route-id="@accommodation.Id" class="btn btn-primary btn-sm">Bewerken</a>
                                <form asp-action="Delete" asp-route-id="@accommodation.Id" asp-route-dayId="@dayId"
                                      method="post" class="inline"
                                      onsubmit="return confirm('Deze accommodatie verwijderen?');">
                                    <button type="submit" class="btn btn-danger btn-sm">Verwijderen</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<a asp-controller="Day" asp-action="Index" asp-route-quoteId="@quoteId" class="btn-link mt-6 inline-block text-sm font-semibold">Terug naar dag-tot-dag</a>

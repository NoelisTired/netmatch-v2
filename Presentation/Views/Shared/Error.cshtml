@model ErrorViewModel
@{
    ViewData["Title"] = "Fout";
}

<h1 class="h3 mb-3 text-danger">Er is een fout opgetreden</h1>

<p class="text-muted">Er ging iets mis bij het verwerken van je verzoek. Probeer het opnieuw.</p>

@if (Model.ShowRequestId)
{
    <p>
        <strong>Request ID:</strong> <code>@Model.RequestId</code>
    </p>
}

<a asp-controller="Quote" asp-action="Index" class="btn btn-link">Terug naar offertes</a>

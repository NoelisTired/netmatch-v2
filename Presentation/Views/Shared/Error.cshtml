@model ErrorViewModel
@{
    ViewData["Title"] = "Fout";
}

<div class="mb-8 reveal">
    <h1 class="font-display text-3xl font-bold" style="color:#f87171;">Er is een fout opgetreden</h1>
</div>

<div class="card-glass reveal p-6">
    <p style="color:var(--text-secondary);">Er ging iets mis bij het verwerken van je verzoek. Probeer het opnieuw.</p>

    @if (Model.ShowRequestId)
    {
        <p style="color:var(--text-secondary);">
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <a asp-controller="Quote" asp-action="Index" class="btn-link mt-6 inline-block text-sm font-semibold">Terug naar offertes</a>
</div>

@model ErrorViewModel
@{
    ViewData["Title"] = L["Fout"];
    ViewData["Crumbs"] = new (string, string?)[] { (L["Fout"].Value, null) };
}

<div class="mx-auto max-w-lg py-10">
    <div class="card p-8 text-center">
        <span class="mx-auto grid h-12 w-12 place-items-center rounded-full"
              style="background:var(--danger-bg); color:var(--danger);">
            <i data-lucide="alert-triangle" class="h-6 w-6"></i>
        </span>
        <h1 class="mt-4 text-lg font-semibold" style="color:var(--text-primary);">@L["Er is een fout opgetreden"]</h1>
        <p class="mt-2 text-sm leading-relaxed" style="color:var(--text-secondary);">
            @L["Er ging iets mis bij het verwerken van je verzoek. Probeer het opnieuw."]
        </p>

        @if (Model.ShowRequestId)
        {
            <p class="mt-4 rounded-lg border px-3 py-2 text-xs"
               style="border-color:var(--border); background:var(--bg-subtle); color:var(--text-tertiary);">
                Request ID: <code class="font-mono">@Model.RequestId</code>
            </p>
        }

        <div class="mt-6 flex justify-center gap-2.5">
            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">@L["Naar dashboard"]</a>
            <a asp-controller="Quote" asp-action="Index" class="btn btn-primary">@L["Naar offertes"]</a>
        </div>
    </div>
</div>

@using System.Globalization
@{
    var culture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var languages = new (string Code, string Label)[]
    {
        ("nl", "Nederlands"), ("en", "English"), ("de", "Deutsch"), ("fr", "Français")
    };
    var activeController = (ViewContext.RouteData.Values["controller"] as string) ?? "";
    string NavActive(params string[] controllers) =>
        controllers.Contains(activeController, StringComparer.OrdinalIgnoreCase) ? "is-active" : "";
}
<!DOCTYPE html>
<html lang="@culture" class="dark">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] · TourWeb Portal</title>
    <script>
        // Pas thema toe voor eerste paint zodat er geen flits is.
        (function () {
            try {
                var saved = localStorage.getItem('tw-theme');
                var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                var dark = saved ? saved === 'dark' : prefersDark;
                document.documentElement.classList.toggle('dark', dark);
            } catch (e) { /* laat standaard dark staan */ }
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap">
    <link rel="stylesheet" href="~/css/build.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/Presentation.styles.css" asp-append-version="true"/>
</head>
<body>
<div class="app-bg"></div>

<header class="sticky top-0 z-40 backdrop-blur-md" style="background:color-mix(in srgb, var(--bg-primary) 78%, transparent); border-bottom:1px solid var(--card-border);">
    <nav class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-3">
        <a class="group flex items-center gap-3" asp-controller="Home" asp-action="Index">
            <span class="grid h-9 w-9 place-items-center rounded-xl font-display text-sm font-bold text-[#04122a]"
                  style="background-image:linear-gradient(135deg, var(--color-cyan), var(--color-violet));">TW</span>
            <span class="flex flex-col leading-none">
                <span class="font-display text-lg font-bold tracking-tight" style="color:var(--text-primary);">TourWeb Portal</span>
                <span class="text-[0.62rem] font-semibold uppercase tracking-[0.18em]" style="color:var(--text-secondary);">by NetMatch</span>
            </span>
        </a>

        <button type="button" id="nav-toggle" class="btn btn-ghost btn-sm sm:hidden" aria-label="Menu" aria-expanded="false">
            <span class="block h-0.5 w-4 bg-current"></span>
        </button>

        <div id="nav-menu" class="hidden w-full flex-col gap-4 sm:flex sm:w-auto sm:flex-row sm:items-center">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:gap-6">
                <a class="nav-link @NavActive("Home")" asp-controller="Home" asp-action="Index">@L["Home"]</a>
                <a class="nav-link @NavActive("Quote", "Day", "Transport", "Accommodation", "RoomType")" asp-controller="Quote" asp-action="Index">@L["Offertes"]</a>
                <a class="nav-link @NavActive("Branding")" asp-controller="Branding" asp-action="Edit">@L["Huisstijl"]</a>
            </div>

            <div class="flex items-center gap-3">
                <form asp-controller="Culture" asp-action="Set" method="post" class="flex items-center gap-2">
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <label class="sr-only" for="culture-select">@L["Taal"]</label>
                    <select id="culture-select" name="culture" class="field !w-auto !py-1.5 !text-sm"
                            onchange="this.form.submit()">
                        @foreach (var lang in languages)
                        {
                            if (lang.Code == culture)
                            {
                                <option value="@lang.Code" selected>@lang.Label</option>
                            }
                            else
                            {
                                <option value="@lang.Code">@lang.Label</option>
                            }
                        }
                    </select>
                </form>

                <button type="button" id="theme-toggle" class="btn btn-ghost btn-sm" aria-label="Thema wisselen" title="Thema wisselen">
                    <span id="theme-icon-dark" class="hidden dark:inline">Licht</span>
                    <span id="theme-icon-light" class="inline dark:hidden">Donker</span>
                </button>
            </div>
        </div>
    </nav>
</header>

<main role="main" class="mx-auto max-w-6xl px-5 py-8">
    @RenderBody()
</main>

<footer class="mt-16" style="border-top:1px solid var(--card-border);">
    <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-2 px-5 py-6 text-sm" style="color:var(--text-secondary);">
        <span>&copy; 2026 TourWeb Portal, een NetMatch product</span>
        <a class="btn-link text-sm" asp-controller="Home" asp-action="Privacy">@L["Privacy"]</a>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
    (function () {
        // Thema-toggle
        var toggle = document.getElementById('theme-toggle');
        if (toggle) {
            toggle.addEventListener('click', function () {
                var isDark = document.documentElement.classList.toggle('dark');
                try { localStorage.setItem('tw-theme', isDark ? 'dark' : 'light'); } catch (e) {}
            });
        }
        // Mobiel menu
        var navToggle = document.getElementById('nav-toggle');
        var navMenu = document.getElementById('nav-menu');
        if (navToggle && navMenu) {
            navToggle.addEventListener('click', function () {
                var open = navMenu.classList.toggle('hidden');
                navToggle.setAttribute('aria-expanded', String(!open));
            });
        }
    })();
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@using System.Globalization
@{
    var culture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var languages = new (string Code, string Label)[]
    {
        ("nl", "Nederlands"), ("en", "English"), ("de", "Deutsch"), ("fr", "Français")
    };
    var activeController = (ViewContext.RouteData.Values["controller"] as string) ?? "";
    string NavActive(params string[] controllers) =>
        controllers.Contains(activeController, StringComparer.OrdinalIgnoreCase) ? "active" : "";
}
<!DOCTYPE html>
<html lang="@culture">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] · TourWeb Portal</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/Presentation.styles.css" asp-append-version="true"/>
</head>
<body>
<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm mb-4">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <span class="brand-mark">TW</span>
                <span class="d-flex flex-column lh-1">
                    TourWeb Portal
                    <span class="brand-sub">by NetMatch</span>
                </span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1 ms-sm-4">
                    <li class="nav-item">
                        <a class="nav-link @NavActive("Home")" asp-controller="Home" asp-action="Index">@L["Home"]</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @NavActive("Quote", "Day", "Transport", "Accommodation", "RoomType")" asp-controller="Quote" asp-action="Index">@L["Offertes"]</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @NavActive("Branding")" asp-controller="Branding" asp-action="Edit">@L["Huisstijl"]</a>
                    </li>
                </ul>
                <form asp-controller="Culture" asp-action="Set" method="post" class="d-flex align-items-center">
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <label class="me-2 text-muted small mb-0" for="culture-select">@L["Taal"]</label>
                    <select id="culture-select" name="culture" class="form-select form-select-sm w-auto"
                            onchange="this.form.submit()">
                        @foreach (var lang in languages)
                        {
                            if (lang.Code == culture)
                            {
                                <option value="@lang.Code" selected>@lang.Label</option>
                            }
                            else
                            {
                                <option value="@lang.Code">@lang.Label</option>
                            }
                        }
                    </select>
                </form>
            </div>
        </div>
    </nav>
</header>
<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted">
    <div class="container d-flex justify-content-between align-items-center flex-wrap">
        <span>&copy; 2026 TourWeb Portal — <span class="nm-product">a NetMatch product</span></span>
        <a asp-controller="Home" asp-action="Privacy">@L["Privacy"]</a>
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>

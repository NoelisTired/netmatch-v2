@model Presentation.Models.BrandingViewModel
@{
    ViewData["Title"] = L["Huisstijl"];
}

<div class="mb-8 reveal">
    <p class="eyebrow mb-2">TourWeb Portal</p>
    <h1 class="font-display text-3xl font-bold sm:text-4xl">@L["Huisstijl"]</h1>
</div>

@if (TempData["BrandingSaved"] is string saved)
{
    <div class="alert alert-success reveal mb-4">@saved</div>
}

<div asp-validation-summary="All" class="mb-4 text-sm" style="color:#f87171;"></div>

<div class="grid gap-5 lg:grid-cols-2">
    <div class="card-glass reveal p-6">
        <form asp-action="Edit" method="post" enctype="multipart/form-data" class="space-y-5">
            <div>
                <label class="field-label">@L["Huidig logo"]</label>
                @if (!string.IsNullOrWhiteSpace(Model.LogoPath))
                {
                    <img src="@Model.LogoPath" alt="@L["Huidig logo"]" class="max-h-16 rounded-lg border p-1" style="border-color:var(--card-border);" />
                }
                else
                {
                    <span class="text-sm" style="color:var(--text-secondary);">@L["Nog geen logo ingesteld."]</span>
                }
            </div>

            <div>
                <label asp-for="Logo" class="field-label">@L["Nieuw logo"] <span class="font-normal opacity-70">(PNG, JPG, SVG, max 2 MB)</span></label>
                <input asp-for="Logo" type="file" accept=".png,.jpg,.jpeg,.svg" class="field" id="logoInput" />
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
                <div>
                    <label asp-for="PrimaryColor" class="field-label">@L["Primaire kleur"]</label>
                    <div class="flex items-center gap-3">
                        <input asp-for="PrimaryColor" type="color" class="h-10 w-14 cursor-pointer rounded-lg border bg-transparent p-1" style="border-color:var(--card-border);" id="primaryColor" />
                        <code class="text-sm" style="color:var(--text-secondary);" id="primaryColorHex">@Model.PrimaryColor</code>
                    </div>
                </div>
                <div>
                    <label asp-for="AccentColor" class="field-label">@L["Accentkleur"]</label>
                    <div class="flex items-center gap-3">
                        <input asp-for="AccentColor" type="color" class="h-10 w-14 cursor-pointer rounded-lg border bg-transparent p-1" style="border-color:var(--card-border);" id="accentColor" />
                        <code class="text-sm" style="color:var(--text-secondary);" id="accentColorHex">@Model.AccentColor</code>
                    </div>
                </div>
            </div>

            <div class="flex items-center gap-3 pt-1">
                <button type="submit" class="btn btn-primary">@L["Opslaan"]</button>
                <a asp-controller="Quote" asp-action="Index" class="btn-link text-sm font-semibold">@L["Terug naar offertes"]</a>
            </div>
        </form>
    </div>

    <div class="card-glass reveal p-6">
        <p class="eyebrow mb-4">@L["Voorbeeld"]</p>

        <div class="mb-4 flex items-center justify-between rounded-xl p-4"
             id="brandPreviewHeader"
             style="border-left:6px solid @Model.PrimaryColor; background:#f8f9fa;">
            <div class="flex items-center gap-3">
                <img id="brandPreviewLogo"
                     src="@(string.IsNullOrWhiteSpace(Model.LogoPath) ? "" : Model.LogoPath)"
                     alt="logo"
                     class="max-h-10"
                     style="@(string.IsNullOrWhiteSpace(Model.LogoPath) ? "display:none;" : "")" />
                <div>
                    <strong id="brandPreviewTitle" style="color:@Model.PrimaryColor;">@L["Voorbeeldofferte"]</strong>
                    <div class="text-xs text-slate-500">NL, @L["Voorbeeld"]</div>
                </div>
            </div>
            <span class="rounded-full px-3 py-1 text-xs font-semibold text-white" id="brandPreviewBadge" style="background:@Model.AccentColor;">concept</span>
        </div>

        <div class="flex flex-wrap gap-2">
            <span class="rounded-lg px-3 py-1.5 text-sm font-semibold text-white" id="brandPreviewBtnPrimary"
                  style="background:@Model.PrimaryColor;">@L["Dag toevoegen"]</span>
            <span class="rounded-lg px-3 py-1.5 text-sm font-semibold text-white" id="brandPreviewBtnAccent"
                  style="background:@Model.AccentColor;">@L["Download PDF"]</span>
        </div>

        <p class="mt-4 text-sm" style="color:var(--text-secondary);">@L["Zo zien je kleuren en logo eruit op een offerte voor je klant."]</p>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const primary = document.getElementById('primaryColor');
            const accent = document.getElementById('accentColor');
            const primaryHex = document.getElementById('primaryColorHex');
            const accentHex = document.getElementById('accentColorHex');
            const header = document.getElementById('brandPreviewHeader');
            const title = document.getElementById('brandPreviewTitle');
            const badge = document.getElementById('brandPreviewBadge');
            const btnPrimary = document.getElementById('brandPreviewBtnPrimary');
            const btnAccent = document.getElementById('brandPreviewBtnAccent');
            const logoInput = document.getElementById('logoInput');
            const logoImg = document.getElementById('brandPreviewLogo');

            function applyPrimary() {
                header.style.borderLeftColor = primary.value;
                title.style.color = primary.value;
                btnPrimary.style.background = primary.value;
                primaryHex.textContent = primary.value;
            }
            function applyAccent() {
                badge.style.background = accent.value;
                btnAccent.style.background = accent.value;
                accentHex.textContent = accent.value;
            }
            primary.addEventListener('input', applyPrimary);
            accent.addEventListener('input', applyAccent);

            logoInput.addEventListener('change', function () {
                const file = this.files && this.files[0];
                if (!file) return;
                const url = URL.createObjectURL(file);
                logoImg.src = url;
                logoImg.style.display = '';
            });
        })();
    </script>
}

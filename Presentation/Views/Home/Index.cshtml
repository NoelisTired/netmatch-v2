@{
    ViewData["Title"] = L["Home"];
}

<section class="card-glass reveal px-7 py-12 sm:px-12 sm:py-14">
    <div class="max-w-2xl">
        <p class="eyebrow mb-4">
            <span class="inline-block h-1.5 w-1.5 rounded-full" style="background:var(--accent);"></span>
            TourWeb Portal, by NetMatch
        </p>
        <h1 class="font-display text-4xl font-bold leading-[1.08] sm:text-5xl">
            @L["Reisoffertes die"] <span class="text-gradient">@L["indruk maken"]</span>
        </h1>
        <p class="mt-5 max-w-xl text-base leading-relaxed sm:text-lg" style="color:var(--text-secondary);">
            @L["Stel gepersonaliseerde reisoffertes samen: per offerte een dag-tot-dag programma met transport, accommodatie en een prijsoverzicht."]
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
            <a asp-controller="Quote" asp-action="Index" class="btn btn-primary">@L["Naar offertes"]</a>
            <a asp-controller="Quote" asp-action="Create" class="btn btn-ghost">@L["Nieuwe offerte aanmaken"]</a>
        </div>
    </div>
</section>

<div class="mt-5 grid gap-4 sm:grid-cols-3">
    <a asp-controller="Quote" asp-action="Index"
       class="card-glass card-glass-hover reveal block p-6" style="animation-delay:.06s;">
        <span class="grid h-9 w-9 place-items-center rounded-lg font-display text-sm font-bold"
              style="background:var(--accent-soft); color:var(--accent);">01</span>
        <div class="mt-4 font-display text-lg font-semibold" style="color:var(--text-primary);">@L["Offertes beheren"]</div>
        <p class="mt-1 text-sm" style="color:var(--text-secondary);">@L["Bekijk, bewerk en exporteer al je reisoffertes."]</p>
    </a>
    <a asp-controller="Quote" asp-action="Create"
       class="card-glass card-glass-hover reveal block p-6" style="animation-delay:.12s;">
        <span class="grid h-9 w-9 place-items-center rounded-lg font-display text-sm font-bold"
              style="background:var(--accent-soft); color:var(--accent);">02</span>
        <div class="mt-4 font-display text-lg font-semibold" style="color:var(--text-primary);">@L["Nieuwe offerte aanmaken"]</div>
        <p class="mt-1 text-sm" style="color:var(--text-secondary);">@L["Begin een nieuwe reisofferte van de grond af op."]</p>
    </a>
    <a asp-controller="Branding" asp-action="Edit"
       class="card-glass card-glass-hover reveal block p-6" style="animation-delay:.18s;">
        <span class="grid h-9 w-9 place-items-center rounded-lg font-display text-sm font-bold"
              style="background:var(--accent-soft); color:var(--accent);">03</span>
        <div class="mt-4 font-display text-lg font-semibold" style="color:var(--text-primary);">@L["Huisstijl"]</div>
        <p class="mt-1 text-sm" style="color:var(--text-secondary);">@L["Stel je logo en kleuren in voor offertes met je eigen huisstijl."]</p>
    </a>
</div>

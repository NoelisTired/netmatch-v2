@using Logic.Models
@model IEnumerable<RoomType>
@{
    var accommodationId = (int)ViewBag.AccommodationId;
    var dayId = (int)ViewBag.DayId;
    ViewData["Title"] = "Kamertypes";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-0">Kamertypes</h1>
        <small class="text-muted">@ViewBag.AccommodationName</small>
    </div>
    <a asp-action="Create" asp-route-accommodationId="@accommodationId" class="btn btn-primary">Kamertype toevoegen</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Deze accommodatie heeft nog geen kamertypes.</div>
}
else
{
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Naam</th>
                <th>Prijs per nacht</th>
                <th>Capaciteit</th>
                <th class="text-end">Acties</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var roomType in Model)
            {
                <tr>
                    <td>@roomType.Name</td>
                    <td>&euro; @roomType.PricePerNight.ToString("0.00")</td>
                    <td>@roomType.Capacity p.</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@roomType.Id" class="btn btn-sm btn-outline-primary">Bewerken</a>
                        <form asp-action="Delete" asp-route-id="@roomType.Id" asp-route-accommodationId="@accommodationId"
                              method="post" class="d-inline"
                              onsubmit="return confirm('Dit kamertype verwijderen?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Verwijderen</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<a asp-controller="Accommodation" asp-action="Index" asp-route-dayId="@dayId" class="btn btn-link">Terug naar accommodatie</a>

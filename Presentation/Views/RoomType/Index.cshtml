@using Logic.Models
@model IEnumerable<RoomType>
@{
    var accommodationId = (int)ViewBag.AccommodationId;
    var dayId = (int)ViewBag.DayId;
    ViewData["Title"] = "Kamertypes";
}

<div class="mb-8 flex flex-wrap items-end justify-between gap-4 reveal">
    <div>
        <p class="eyebrow mb-2">@ViewBag.AccommodationName</p>
        <h1 class="font-display text-3xl font-bold sm:text-4xl">Kamertypes</h1>
    </div>
    <a asp-action="Create" asp-route-accommodationId="@accommodationId" class="btn btn-accent">Kamertype toevoegen</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info reveal">Deze accommodatie heeft nog geen kamertypes.</div>
}
else
{
    <div class="card-glass reveal overflow-hidden">
        <table class="table-glass">
            <thead>
                <tr>
                    <th>Naam</th>
                    <th>Prijs per nacht</th>
                    <th>Capaciteit</th>
                    <th class="text-right">Acties</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var roomType in Model)
                {
                    <tr>
                        <td>@roomType.Name</td>
                        <td>&euro; @roomType.PricePerNight.ToString("0.00")</td>
                        <td>@roomType.Capacity p.</td>
                        <td>
                            <div class="flex flex-wrap justify-end gap-2">
                                <a asp-action="Edit" asp-route-id="@roomType.Id" class="btn btn-ghost btn-sm">Bewerken</a>
                                <form asp-action="Delete" asp-route-id="@roomType.Id" asp-route-accommodationId="@accommodationId"
                                      method="post" class="inline"
                                      onsubmit="return confirm('Dit kamertype verwijderen?');">
                                    <button type="submit" class="btn btn-danger btn-sm">Verwijderen</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<a asp-controller="Accommodation" asp-action="Index" asp-route-dayId="@dayId" class="btn-link mt-6 inline-block text-sm font-semibold">Terug naar accommodatie</a>

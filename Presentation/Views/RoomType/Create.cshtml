@model Presentation.Models.RoomTypeViewModel
@{
    ViewData["Title"] = L["Kamertype toevoegen"];
    ViewData["Crumbs"] = new (string, string?)[]
    {
        (L["Offertes"].Value, Url.Action("Index", "Quote")),
        (L["Kamertype toevoegen"].Value, null)
    };
}

<div class="mb-6">
    <h1 class="text-xl font-semibold" style="color:var(--text-primary);">@L["Kamertype toevoegen"]</h1>
    <p class="mt-0.5 text-sm" style="color:var(--text-secondary);">@L["Voeg een kamertype met prijs en capaciteit toe aan deze accommodatie."]</p>
</div>

<div class="card max-w-2xl">
    <div class="card-header">
        <span class="card-title">@L["Kamertypegegevens"]</span>
    </div>
    <form asp-action="Create" method="post" class="p-5 sm:p-6">
        <div asp-validation-summary="All" class="validation-errors mb-5"></div>
        <input type="hidden" asp-for="AccommodationId"/>

        <div class="space-y-5">
            <div>
                <label asp-for="Name" class="field-label">@L["Naam"] <span class="req">*</span></label>
                <input asp-for="Name" class="field" autofocus placeholder="@L["Bijv. Tweepersoonskamer deluxe"]"/>
            </div>

            <div class="grid gap-5 sm:grid-cols-2">
                <div>
                    <label asp-for="PricePerNight" class="field-label">@L["Prijs per nacht"] <span class="req">*</span></label>
                    <div class="input-affix">
                        <span class="affix">&euro;</span>
                        <input asp-for="PricePerNight" type="number" step="0.01" min="0" placeholder="0,00"/>
                    </div>
                </div>
                <div>
                    <label asp-for="Capacity" class="field-label">@L["Capaciteit"] <span class="req">*</span></label>
                    <div class="input-affix">
                        <span class="affix"><i data-lucide="users" class="h-3.5 w-3.5"></i></span>
                        <input asp-for="Capacity" type="number" min="1"/>
                    </div>
                    <p class="field-hint">@L["Aantal personen per kamer."]</p>
                </div>
            </div>
        </div>

        <div class="mt-6 flex items-center justify-end gap-2.5 border-t pt-5" style="border-color:var(--border);">
            <a asp-action="Index" asp-route-accommodationId="@Model.AccommodationId" class="btn btn-ghost">@L["Annuleren"]</a>
            <button type="submit" class="btn btn-primary">
                <i data-lucide="check" class="h-4 w-4"></i>
                @L["Kamertype opslaan"]
            </button>
        </div>
    </form>
</div>

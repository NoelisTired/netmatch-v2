@model Presentation.Models.RoomTypeViewModel
@{
    ViewData["Title"] = "Kamertype toevoegen";
}

<div class="mb-8 flex flex-wrap items-end justify-between gap-4 reveal">
    <div>
        <p class="eyebrow mb-2">TourWeb Portal</p>
        <h1 class="font-display text-3xl font-bold sm:text-4xl">Kamertype toevoegen</h1>
    </div>
</div>

<div class="card-glass reveal max-w-xl p-6 sm:p-7">
    <div asp-validation-summary="All" class="mb-4 text-sm" style="color:#f87171;"></div>

    <form asp-action="Create" method="post" class="space-y-5">
        <input type="hidden" asp-for="AccommodationId" />

        <div>
            <label asp-for="Name" class="field-label">Naam</label>
            <input asp-for="Name" class="field" autofocus />
        </div>

        <div>
            <label asp-for="PricePerNight" class="field-label">Prijs per nacht (&euro;)</label>
            <input asp-for="PricePerNight" type="number" step="0.01" min="0" class="field" />
        </div>

        <div>
            <label asp-for="Capacity" class="field-label">Capaciteit (personen)</label>
            <input asp-for="Capacity" type="number" min="1" class="field" />
        </div>

        <div class="flex items-center gap-3 pt-1">
            <button type="submit" class="btn btn-primary">Opslaan</button>
            <a asp-action="Index" asp-route-accommodationId="@Model.AccommodationId" class="btn-link text-sm font-semibold">Annuleren</a>
        </div>
    </form>
</div>

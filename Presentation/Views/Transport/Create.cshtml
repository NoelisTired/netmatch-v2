@model Presentation.Models.TransportViewModel
@{
    ViewData["Title"] = "Transport toevoegen";
}

<div class="mb-8 flex flex-wrap items-end justify-between gap-4 reveal">
    <div>
        <p class="eyebrow mb-2">TourWeb Portal</p>
        <h1 class="font-display text-3xl font-bold sm:text-4xl">Transport toevoegen</h1>
    </div>
</div>

<div class="card-glass reveal max-w-2xl p-6 sm:p-7">
    <div asp-validation-summary="All" class="mb-4 text-sm" style="color:#f87171;"></div>

    <form asp-action="Create" method="post" class="space-y-5">
    <input type="hidden" asp-for="DayId" />

    <div>
        <label asp-for="Type" class="field-label">Type</label>
        <select asp-for="Type" class="field">
            <option value="">-- Kies een transporttype --</option>
            <option value="Vlucht">Vlucht</option>
            <option value="Bus">Bus</option>
            <option value="Trein">Trein</option>
            <option value="Eigen vervoer">Eigen vervoer</option>
        </select>
    </div>

    <div>
        <label asp-for="DepartureLocation" class="field-label">Vertreklocatie</label>
        <input asp-for="DepartureLocation" class="field" />
    </div>

    <div>
        <label asp-for="ArrivalLocation" class="field-label">Aankomstlocatie</label>
        <input asp-for="ArrivalLocation" class="field" />
    </div>

    <div>
        <label asp-for="FlightNumber" class="field-label">Vluchtnummer <span style="color:var(--text-secondary);">(verplicht bij Vlucht)</span></label>
        <input asp-for="FlightNumber" class="field" />
    </div>

    <div>
        <label asp-for="Airline" class="field-label">Luchtvaartmaatschappij <span style="color:var(--text-secondary);">(verplicht bij Vlucht)</span></label>
        <input asp-for="Airline" class="field" />
    </div>

    <div>
        <label asp-for="Price" class="field-label">Prijs <span style="color:var(--text-secondary);">(optioneel, in &euro;)</span></label>
        <input asp-for="Price" type="number" step="0.01" min="0" class="field" placeholder="0,00" />
    </div>

    <div class="flex items-center gap-3 pt-1">
        <button type="submit" class="btn btn-primary">Opslaan</button>
        <a asp-action="Index" asp-route-dayId="@Model.DayId" class="btn-link text-sm font-semibold">Annuleren</a>
    </div>
    </form>
</div>

@using Logic.Models
@model IEnumerable<Transport>
@{
    var dayId = (int)ViewBag.DayId;
    var quoteId = (int)ViewBag.QuoteId;
    ViewData["Title"] = "Transport";
}

<div class="mb-8 flex flex-wrap items-end justify-between gap-4 reveal">
    <div>
        <p class="eyebrow mb-2">Dag @ViewBag.DayNumber</p>
        <h1 class="font-display text-3xl font-bold sm:text-4xl">Transport</h1>
    </div>
    <a asp-action="Create" asp-route-dayId="@dayId" class="btn btn-accent">Transport toevoegen</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info reveal">Deze dag heeft nog geen transport.</div>
}
else
{
    <div class="card-glass reveal overflow-hidden">
        <table class="table-glass">
            <thead>
                <tr>
                    <th>Type</th>
                    <th>Van</th>
                    <th>Naar</th>
                    <th>Vlucht</th>
                    <th class="text-right">Acties</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var transport in Model)
                {
                    <tr>
                        <td>@transport.Type</td>
                        <td>@transport.DepartureLocation</td>
                        <td>@transport.ArrivalLocation</td>
                        <td>
                            @if (transport.FlightNumber is not null)
                            {
                                <text>@transport.FlightNumber, @transport.Airline</text>
                            }
                            else
                            {
                                <span style="color:var(--text-secondary);">-</span>
                            }
                        </td>
                        <td class="text-right">
                            <div class="flex flex-wrap justify-end gap-2">
                                <a asp-action="Edit" asp-route-id="@transport.Id" class="btn btn-ghost btn-sm">Bewerken</a>
                                <form asp-action="Delete" asp-route-id="@transport.Id" asp-route-dayId="@dayId"
                                      method="post" class="inline"
                                      onsubmit="return confirm('Dit transport verwijderen?');">
                                    <button type="submit" class="btn btn-danger btn-sm">Verwijderen</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<a asp-controller="Day" asp-action="Index" asp-route-quoteId="@quoteId" class="btn-link">Terug naar dag-tot-dag</a>
